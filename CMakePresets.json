{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default",
      "description": "Default configuration",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/.build"
    },
    {
      "name": "unity",
      "displayName": "Unity",
      "description": "Unity Build Enabled",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/.build_unity",
      "cacheVariables": {
        "CMAKE_UNITY_BUILD": "ON"
      }
    },
    {
      "name": "ci",
      "displayName": "CI",
      "description": "Continuous Integration Build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/.build_ci",
      "cacheVariables": {
        "CMAKE_UNITY_BUILD": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Debug",
      "configurePreset": "default",
      "configuration": "Debug"
    },
    {
      "name": "DebugUnity",
      "configurePreset": "unity",
      "configuration": "Debug"
    },
    {
      "name": "Release",
      "configurePreset": "default",
      "configuration": "Release"
    },
    {
      "name": "ReleaseUnity",
      "configurePreset": "unity",
      "configuration": "Release"
    },
    {
      "name": "ReleaseWithSymbols",
      "configurePreset": "default",
      "configuration": "ReleaseWithSymbols"
    },
    {
      "name": "ReleaseWithSymbolsUnity",
      "configurePreset": "unity",
      "configuration": "ReleaseWithSymbols"
    },
    {
      "name": "CI",
      "configurePreset": "ci",
      "configuration": "Release"
    }
  ]
}
