{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows",
      "displayName": "Windows",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/.build/windows",
      "architecture": "x64",
      "toolset": "host=x64",
      "cacheVariables": {
        "VCPKG_MANIFEST_FEATURES": "testapp"
      }
    },
    {
      "name": "windows-ci",
      "displayName": "Windows CI",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/.build/windows-ci",
      "architecture": "x64",
      "toolset": "host=x64",
      "cacheVariables": {
        "PHX_BUILD_TESTAPP": "OFF",
        "PHX_USE_PCH": "OFF"
      }
    },
    {
      "name": "linux",
      "displayName": "Linux",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/.build/linux",
      "cacheVariables": {
        "VCPKG_MANIFEST_FEATURES": "testapp"
      }
    },
    {
      "name": "linux-ci",
      "displayName": "Linux CI",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/.build/linux-ci",
      "cacheVariables": {
        "PHX_BUILD_TESTAPP": "OFF",
        "PHX_USE_PCH": "OFF"
      }
    },
    {
      "name": "emscripten",
      "displayName": "Emscripten (WebAssembly)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/.build/wasm",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "wasm32-emscripten",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
        "PHX_USE_PCH": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Debug",
      "configurePreset": "windows",
      "configuration": "Debug"
    },
    {
      "name": "Release",
      "configurePreset": "windows",
      "configuration": "Release"
    },
    {
      "name": "ReleaseWithSymbols",
      "configurePreset": "windows",
      "configuration": "ReleaseWithSymbols"
    },
    {
      "name": "EmscriptenRelease",
      "configurePreset": "emscripten",
      "configuration": "Release"
    }
  ]
}
